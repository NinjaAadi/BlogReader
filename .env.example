# ─── Telegram Bot ────────────────────────────────────────
# Get from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_here

# Get by messaging your bot, then visiting:
# https://api.telegram.org/bot<TOKEN>/getUpdates
CHAT_ID=your_telegram_chat_id_here

# ─── Notifications ───────────────────────────────────────
# Comma-separated topics to send Telegram notifications for.
# Leave empty to notify about ALL topics.
# Example: NOTIFY_TOPICS=AI/ML,Security,Big Tech
NOTIFY_TOPICS=

# Hour (UTC, 0-23) to send the daily digest message. Default: 8 = 08:00 UTC
DIGEST_HOUR=8

# ─── Scheduler ───────────────────────────────────────────
# How often to check for new articles (in minutes)
POLL_INTERVAL_MINUTES=300

# ─── Database ────────────────────────────────────────────
DATABASE_URL=./blog_notifier.db

# How many days to retain articles (older ones get deleted daily at 03:00 UTC)
RETAIN_DAYS=90

# ─── Server ──────────────────────────────────────────────
BACKEND_PORT=8000


# Logging mode: "file" (default) or "console"
LOG_MODE=file